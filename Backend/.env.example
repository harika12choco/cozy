PORT=5000
MONGODB_URI=your_mongodb_connection_string

# Razorpay Live/Test API keys — keep the secret ONLY on the backend
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Cloudinary configuration
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ─── Admin credentials ───────────────────────────────────────────────────────
# Set ONLY in Render environment variables — never commit real values.

ADMIN_USERNAME=replace_with_admin_username

# MED-4: Store a bcrypt hash, NOT the plain password.
# Generate with: node -e "require('bcryptjs').hash('YourPassword', 12).then(console.log)"
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash

# Legacy plain-text fallback (deprecated — migrate to ADMIN_PASSWORD_HASH above)
# ADMIN_PASSWORD=replace_with_strong_admin_password

ADMIN_JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
ADMIN_TOKEN_TTL=8h

# ─── Firebase Admin SDK (CRIT-2 fix) ────────────────────────────────────────
# Required for verifying Firebase user tokens on the backend.
# Steps:
#   1. Firebase Console → Project Settings → Service Accounts → Generate new private key
#   2. Download the JSON file
#   3. Base64-encode it:  base64 -w 0 serviceaccount.json
#   4. Paste the output as the value below (Render env var)
FIREBASE_SERVICE_ACCOUNT=base64_encoded_service_account_json

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated allowed frontend domains
# Example: https://your-store.vercel.app,https://www.your-store.com
FRONTEND_URLS=https://your-store.vercel.app

# ─── Site image URLs (Cloudinary) ────────────────────────────────────────────
SITE_IMAGE_CATEGORY_MOMENTS_MEMORIES=https://res.cloudinary.com/your_cloud_name/image/upload/cozy-candles/site-images/moments-memories.jpg
SITE_IMAGE_CATEGORY_GIFTING_COLLECTION=https://res.cloudinary.com/your_cloud_name/image/upload/cozy-candles/site-images/gifting-collection.jpg
SITE_IMAGE_CATEGORY_FESTIVE_COLLECTION=https://res.cloudinary.com/your_cloud_name/image/upload/cozy-candles/site-images/festive-collection.jpg
SITE_IMAGE_CATEGORY_DESSERT_CANDLE_COLLECTION=https://res.cloudinary.com/your_cloud_name/image/upload/cozy-candles/site-images/dessert-candle-collection.jpg
SITE_IMAGE_CATEGORY_FLORAL_AESTHETIC=https://res.cloudinary.com/your_cloud_name/image/upload/cozy-candles/site-images/floral-aesthetic.jpg
SITE_IMAGE_CATEGORY_JAR_BOWL_COLLECTION=https://res.cloudinary.com/your_cloud_name/image/upload/cozy-candles/site-images/jar-bowl-collection.jpg
SITE_IMAGE_CATEGORY_CUSTOMIZED=https://res.cloudinary.com/your_cloud_name/image/upload/cozy-candles/site-images/customized.jpg
SITE_IMAGE_CATEGORY_WEDDING_EVENT=https://res.cloudinary.com/your_cloud_name/image/upload/cozy-candles/site-images/wedding-event.jpg
