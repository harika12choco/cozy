# Backend base URL used by admin and storefront API calls
# Keep /api/products for product service compatibility
VITE_API_URL=https://your-render-backend.onrender.com/api/products

# Optional override used by admin auth/orders/users/messages services
# If not set, it is derived from VITE_API_URL
VITE_API_BASE_URL=https://your-render-backend.onrender.com/api
