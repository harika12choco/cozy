# Backend API URL
VITE_API_BASE_URL=https://cozy-candles-backend.onrender.com/api

# Razorpay public key (safe to expose in frontend)
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# ─── Firebase config (CRIT-1 fix) ───────────────────────────────────────────
# Copy these from Firebase Console → Project Settings → Your apps → Web app
# Set ALL of these in the Vercel dashboard under Environment Variables.
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
